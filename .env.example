# Backend configuration
# Use one stable URL for all production clients.
# Examples:
#   https://api.yourdomain.com/api
#   https://<your-ngrok-or-cloudflare-tunnel>.trycloudflare.com/api
API_BASE_URL=https://api.yourdomain.com/api

# Optional explicit WebSocket URL if you want a separate realtime host.
# If omitted, the app derives wss/ws from API_BASE_URL automatically.
# SOCKET_BASE_URL=https://api.yourdomain.com

# Development only: if you insist on local testing without a tunnel,
# use emulator + adb reverse or your local backend host.
# BACKEND_BASE_URL=http://10.0.2.2:8000/api
